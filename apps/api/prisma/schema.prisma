// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AssetType {
  STOCK
  CRYPTO
  REAL_ESTATE
  BOND
  CASH
  OTHER
}

enum TxType {
  BUY
  SELL
  DEPOSIT
  WITHDRAWAL
  DIVIDEND
}

enum NotifType {
  SUCCESS
  WARNING
  INFO
  ERROR
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  profile       Profile?
  settings      Settings?
  refreshTokens RefreshToken[]
  assets        Asset[]
  transactions  Transaction[]
  notifications Notification[]

  @@index([email])
}

model Profile {
  userId    String  @id
  fullName  String?
  avatarUrl String?
  bio       String?
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  userId               String  @id
  themePreference      String  @default("system")
  notificationsEnabled Boolean @default(true)
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Asset {
  id           String    @id @default(uuid())
  userId       String
  symbol       String
  name         String
  shares       Decimal   @db.Decimal(18, 8)
  avgCost      Decimal   @db.Decimal(18, 2)
  currentPrice Decimal   @db.Decimal(18, 2)
  assetType    AssetType @default(STOCK)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  type      TxType
  symbol    String?
  name      String?
  amount    Decimal  @db.Decimal(18, 2)
  price     Decimal? @db.Decimal(18, 2)
  shares    Decimal? @db.Decimal(18, 8)
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean   @default(false)
  type      NotifType @default(INFO)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
